---
import Layout from '../layouts/Layout.astro';
import StatCard from '../components/shared/StatCard.astro';
import ServiceCard from '../components/shared/ServiceCard.astro';
import AuditModal from '../components/shared/AuditModal.astro';
import UseCasesSection from '../components/sections/UseCasesSection.astro';
import ValuesSection from '../components/sections/ValuesSection.astro';
import type { IconName } from '../utils/icons';

const seoTitle = "Alefia — Agence IA & Automatisation pour PME, TPE et Indépendants | Paris";
const seoDescription = "Automatisez vos processus métier avec des agents IA sur mesure. Workflows n8n, Make, Zapier, intégration CRM. Gagnez +10h/semaine. Audit IA gratuit — Réponse sous 48h.";

const stats: { number: string; label: string; description: string; icon: IconName }[] = [
  { number: "+10h", label: "Gagnées par semaine en moyenne", description: "Automatisation des tâches répétitives", icon: "clock" },
  { number: "-60%", label: "Réduction du travail manuel", description: "Workflows intelligents sur mesure", icon: "trending-up" },
  { number: "48h", label: "Pour déployer votre 1er agent IA", description: "Résultats rapides, sans friction", icon: "rocket" },
];

const expertises: { title: string; description: string; icon: IconName }[] = [
  { title: "Agents IA sur mesure", description: "Automatisez vos devis, emails, relances et reportings avec des agents IA adaptés à votre métier.", icon: "settings" },
  { title: "Automatisation de workflows", description: "n8n, Make, Zapier — connectez tous vos outils et éliminez les tâches manuelles répétitives.", icon: "chart" },
  { title: "Intégration IA dans vos outils", description: "Connectez l'IA à votre CRM, ERP et outils existants sans changer votre organisation.", icon: "tools" },
  { title: "Analyse de données IA", description: "Dashboards automatiques, reporting IA et insights actionnables en temps réel.", icon: "chart" },
  { title: "Formation & conseil IA", description: "Stratégie IA, formation de vos équipes et accompagnement pour une adoption durable.", icon: "heart" },
];

const clients = [
  "BNP Paribas",
  "Hello bank!",
  "Crédit Mutuel",
  "CIC",
  "Société Générale",
  "Wonderbox"
];
---

<Layout title={seoTitle} description={seoDescription}>
  <AuditModal />

  <!-- JSON-LD Structured Data -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Alefia",
    "description": "Agence spécialisée en automatisation IA et développement d'agents IA pour PME, TPE et indépendants.",
    "url": "https://alefia.co",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "35 Rue du Faubourg Poissonnière",
      "addressLocality": "Paris",
      "postalCode": "75009",
      "addressCountry": "FR"
    },
    "areaServed": "France",
    "serviceType": ["Automatisation IA", "Agents IA", "Intégration IA", "Formation IA"],
    "priceRange": "Sur devis"
  })} />

  <!-- Hero Section -->
  <section class="pt-40 pb-28 bg-gradient-to-b from-primary to-primary-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/grid.svg')] opacity-10"></div>
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-secondary/20 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-secondary/20 rounded-full blur-3xl"></div>

    <div class="container mx-auto px-4 relative">
      <div class="max-w-4xl mx-auto text-center">
        <div class="mb-8 inline-flex items-center bg-white/10 rounded-full px-6 py-3 backdrop-blur-sm border border-white/10">
          <span class="text-sm font-medium ml-2">Experts IA & Automatisation</span>
        </div>
        <h1 class="text-5xl md:text-7xl font-bold mb-8 leading-tight">
          <span class="text-secondary bg-gradient-to-r from-secondary to-secondary-light bg-clip-text text-transparent">Automatisez</span> votre business <span class="text-secondary bg-gradient-to-r from-secondary to-secondary-light bg-clip-text text-transparent">avec l'IA</span>
        </h1>
        <p class="text-xl md:text-2xl mb-12 text-gray-200 leading-relaxed">
          Agents IA, automatisation de workflows, intégration dans vos outils.<br/>
          Gagnez du temps, réduisez vos coûts. Sans compétences techniques requises.
        </p>

        <!-- CTA -->
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-8 max-w-2xl mx-auto border border-white/10 shadow-xl">
          <div class="flex flex-col md:flex-row gap-4">
            <input
              type="email"
              id="home-email-input"
              placeholder="Votre email professionnel"
              class="flex-1 px-6 py-4 rounded-xl text-gray-900 bg-white/95 focus:ring-2 focus:ring-secondary focus:bg-white transition-all duration-200"
            >
            <button
              type="button"
              id="audit-button"
              class="bg-secondary hover:bg-secondary-light text-primary font-semibold px-8 py-4 rounded-xl transition-all duration-200 hover:shadow-lg hover:scale-105 whitespace-nowrap"
            >
              Audit IA gratuit
            </button>
          </div>
          <p class="text-sm mt-4 text-gray-300">Sans engagement • Réponse sous 48h • 100% gratuit</p>
        </div>

        <!-- Preuve sociale courte -->
        <p class="mt-8 text-gray-300 text-sm">
          Ils nous font confiance : <span class="font-semibold text-white">BNP Paribas, Crédit Mutuel, Wonderbox</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Cas d'usage -->
  <UseCasesSection />

  <!-- Stats -->
  <section class="py-20 bg-neutral-100" aria-label="Résultats mesurables">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Des résultats concrets et mesurables</h2>
        <p class="text-gray-600 text-lg">
          Nos clients PME, TPE et indépendants gagnent en productivité dès les premières semaines.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {stats.map(stat => (
          <StatCard {...stat} />
        ))}
      </div>
    </div>
  </section>

  <!-- Valeurs -->
  <ValuesSection />

  <!-- Nos expertises -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Nos domaines d'expertise</h2>
      <p class="text-gray-600 text-center mb-16 max-w-2xl mx-auto">
        De la stratégie IA au déploiement opérationnel — nous couvrons tout le spectre de l'automatisation intelligente.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {expertises.map(service => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <!-- Références clients -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Ils nous font confiance</h2>
      <p class="text-gray-500 text-center mb-12 max-w-xl mx-auto">
        Des grands groupes aux TPE, nos solutions d'automatisation IA s'adaptent à toutes les tailles d'entreprise.
      </p>
      <div class="flex flex-wrap justify-center items-center gap-6 max-w-4xl mx-auto">
        {clients.map(client => (
          <div class="bg-gray-50 border border-gray-200 rounded-xl px-8 py-4 text-gray-700 font-semibold text-lg hover:border-primary hover:text-primary transition-all duration-200">
            {client}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="bg-primary text-white py-20">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-6">Prêt à gagner du temps avec l'IA ?</h2>
      <p class="text-xl mb-8 text-gray-200">
        Obtenez votre audit IA gratuit et découvrez quelles tâches automatiser en priorité.
      </p>
      <button
        type="button"
        onclick="openModal()"
        class="bg-secondary hover:bg-secondary-light text-primary font-semibold px-8 py-4 rounded-lg transition-colors text-lg"
      >
        Démarrer mon audit gratuit
      </button>
      <p class="text-sm mt-4 text-gray-300">Réponse personnalisée sous 48h • Sans engagement</p>
    </div>
  </section>
</Layout>
