---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/shared/Icon.astro';
import AuditModal from '../../components/shared/AuditModal.astro';
import type { IconName } from '../../utils/icons';

const seoTitle = "Nos Services — Agents IA & Automatisation pour PME et TPE | Alefia Paris";
const seoDescription = "Développement d'agents IA sur mesure, automatisation de workflows (n8n, Make, Zapier), intégration IA dans vos outils et formation équipes. Déploiement en 48h.";

const steps = [
  {
    num: "01",
    title: "Audit de vos processus",
    desc: "On identifie ensemble les tâches répétitives qui consomment votre temps. L'audit est gratuit, sans engagement, et dure 20 minutes.",
    points: [
      "Cartographie de vos processus manuels actuels",
      "Identification des 3 automatisations à fort impact",
      "Estimation du temps récupérable chaque semaine"
    ]
  },
  {
    num: "02",
    title: "Conception de la solution",
    desc: "On conçoit l'automatisation adaptée à vos outils existants — sans tout réinventer, sans tout changer.",
    points: [
      "Choix des outils : n8n, Make, Zapier, Claude Agents",
      "Intégration avec votre CRM, messagerie, ERP existant",
      "Prototype validé avec vous avant déploiement"
    ]
  },
  {
    num: "03",
    title: "Déploiement en 48h",
    desc: "Le premier agent IA ou workflow automatisé est opérationnel en 48h. Vous voyez les résultats immédiatement.",
    points: [
      "Déploiement sans interruption de votre activité",
      "Tests en conditions réelles avec vos données",
      "Ajustements en temps réel selon vos retours"
    ]
  },
  {
    num: "04",
    title: "Formation & accompagnement",
    desc: "Vos équipes prennent en main les outils facilement — on s'assure que l'adoption est complète et durable.",
    points: [
      "Formation pratique adaptée à chaque profil",
      "Documentation simple et accessible",
      "Support continu pour ajustements et évolutions"
    ]
  }
];

const keyFactors: { icon: IconName; title: string; desc: string }[] = [
  { icon: 'trending-up', title: 'Résultats en 48h', desc: 'Pas de déploiement de 6 mois. Le premier résultat est visible en deux jours.' },
  { icon: 'settings', title: "S'intègre à vos outils", desc: "On se connecte à ce que vous utilisez déjà — sans tout changer ni tout réapprendre." },
  { icon: 'shield', title: 'Sans compétences requises', desc: "Vos équipes n'ont besoin d'aucune formation technique. On gère la complexité pour vous." },
];
---

<Layout title={seoTitle} description={seoDescription}>
  <AuditModal />

  <!-- Hero -->
  <section class="bg-gradient-to-b from-gray-50 to-white pt-36 pb-16">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center bg-primary/10 text-primary rounded-full px-5 py-2 text-sm font-medium mb-6">
          Nos services
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
          Automatisation IA &amp; Agents IA<br/>pour votre entreprise
        </h1>
        <p class="text-xl text-gray-600 mb-10">
          De l'audit à la mise en production — on automatise vos processus répétitifs avec des agents IA sur mesure, déployés en 48h.
        </p>
        <button
          type="button"
          onclick="openModal()"
          class="bg-primary text-white px-8 py-4 rounded-xl font-semibold hover:bg-primary-dark transition-colors inline-flex items-center gap-2"
        >
          Obtenir mon audit gratuit
          <Icon name="arrow-right" class="w-5 h-5" />
        </button>
        <p class="text-sm text-gray-400 mt-3">Sans engagement • Réponse sous 48h</p>
      </div>
    </div>
  </section>

  <!-- Notre méthode -->
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <h2 class="text-3xl font-bold mb-6">Notre méthode en 4 étapes</h2>
        <p class="text-lg text-gray-700">
          Simple, rapide, orienté résultats. Du premier échange au déploiement, on vous guide à chaque étape.
        </p>
      </div>

      <div class="space-y-16">
        {steps.map((step, i) => (
          <div class={`flex flex-col ${i % 2 === 1 ? 'md:flex-row-reverse' : 'md:flex-row'} gap-8 items-center`}>
            <div class="md:w-1/2">
              <div class="inline-block bg-primary text-white text-xl font-bold px-4 py-2 rounded-lg mb-4">{step.num}</div>
              <h3 class="text-2xl font-bold mb-4">{step.title}</h3>
              <p class="text-gray-700 mb-6">{step.desc}</p>
              <div class="space-y-4">
                {step.points.map(point => (
                  <div class="flex items-start">
                    <div class="bg-primary/10 p-2 rounded-full mr-3 mt-1">
                      <Icon name="check-circle" class="w-5 h-5 text-primary" />
                    </div>
                    <p class="text-gray-600">{point}</p>
                  </div>
                ))}
              </div>
            </div>
            <div class="md:w-1/2 bg-primary/5 rounded-2xl p-12 flex items-center justify-center">
              <div class="text-6xl font-black text-primary/20">{step.num}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Facteurs clés -->
  <section class="bg-gray-50 py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-3xl font-bold mb-6">Ce qui nous différencie</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {keyFactors.map(factor => (
          <div class="bg-white p-6 rounded-xl shadow-sm">
            <div class="text-primary mb-4">
              <Icon name={factor.icon} class="w-10 h-10" />
            </div>
            <h3 class="text-xl font-semibold mb-3">{factor.title}</h3>
            <p class="text-gray-600">{factor.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-8">Prêt à automatiser vos processus ?</h2>
      <p class="text-xl text-gray-600 mb-8 max-w-3xl mx-auto">
        Commencez par un audit gratuit de 20 minutes. On vous dit exactement quoi automatiser et combien de temps vous récupérez.
      </p>
      <button
        type="button"
        onclick="openModal()"
        class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-10 py-4 rounded-xl transition-colors text-lg"
      >
        Démarrer mon audit gratuit
      </button>
      <p class="text-sm text-gray-400 mt-3">Sans engagement • Réponse sous 48h</p>
    </div>
  </section>
</Layout>
