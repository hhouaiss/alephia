---
import Layout from '../layouts/Layout.astro';
import AuditModal from '../components/shared/AuditModal.astro';
import Icon from '../components/shared/Icon.astro';

const seoTitle = "Contact — Alefia | Agence IA & Automatisation Paris";
const seoDescription = "Contactez Alefia pour votre projet d'automatisation IA. Audit gratuit disponible. Réponse sous 48h. Email, téléphone, ou formulaire en ligne.";

const faqs = [
  {
    question: "Comment fonctionne l'audit IA gratuit ?",
    answer: "Remplissez le formulaire en 30 secondes (prénom + email + besoin optionnel). Nous vous contactons sous 48h pour un échange de 20 minutes. Vous repartez avec une liste concrète des processus à automatiser en priorité et une estimation du temps gagné."
  },
  {
    question: "L'automatisation IA est-elle complexe à mettre en place ?",
    answer: "Non. Nous nous occupons de tout — de la conception au déploiement. Vos équipes n'ont pas besoin de compétences techniques. Le premier agent IA peut être opérationnel en 48h."
  },
  {
    question: "Pour quelle taille d'entreprise travaillez-vous ?",
    answer: "Nous accompagnons les TPE (1–9 salariés), les PME (10–250 salariés) et les indépendants. Nos solutions s'adaptent à chaque taille et à chaque budget."
  },
  {
    question: "Combien coûte l'automatisation de mes processus ?",
    answer: "L'audit initial est 100% gratuit et sans engagement. Les projets d'automatisation sont ensuite proposés sur devis, en fonction du périmètre. Nous commençons toujours par les actions à fort impact et faible complexité."
  },
  {
    question: "Mes données sont-elles en sécurité ?",
    answer: "Oui. Nous ne conservons aucune donnée sensible de votre entreprise sans accord explicite. Toutes nos intégrations respectent les bonnes pratiques de sécurité et les exigences RGPD."
  }
];
---

<Layout title={seoTitle} description={seoDescription}>
  <AuditModal />

  <!-- Page Header -->
  <div class="bg-primary text-white pt-40 pb-20">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Contactez-nous</h1>
      <p class="text-xl max-w-3xl text-gray-200">
        Un projet d'automatisation IA ? Une question sur nos services ? On vous répond sous 48h.
      </p>
    </div>
  </div>

  <!-- Contact Section -->
  <section class="py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl shadow-xl p-8 mb-12">
          <h2 class="text-2xl font-bold mb-8 text-center">Nos coordonnées</h2>

          <div class="grid md:grid-cols-2 gap-8">
            <div class="flex items-start">
              <div class="bg-primary/10 p-3 rounded-full mr-4">
                <Icon name="map-pin" class="w-6 h-6 text-primary" />
              </div>
              <div>
                <h3 class="font-semibold text-lg">Adresse</h3>
                <p class="text-gray-600 mt-1">
                  35 Rue du Faubourg Poissonnière<br />
                  75009 Paris, France
                </p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-primary/10 p-3 rounded-full mr-4">
                <Icon name="mail" class="w-6 h-6 text-primary" />
              </div>
              <div>
                <h3 class="font-semibold text-lg">Email</h3>
                <a href="mailto:hello@alefia.co" class="text-primary hover:underline mt-1 block">
                  hello@alefia.co
                </a>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-primary/10 p-3 rounded-full mr-4">
                <Icon name="phone" class="w-6 h-6 text-primary" />
              </div>
              <div>
                <h3 class="font-semibold text-lg">Téléphone</h3>
                <a href="tel:+33983699562" class="text-primary hover:underline mt-1 block">
                  09 83 69 95 62 (non surtaxé)
                </a>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-primary/10 p-3 rounded-full mr-4">
                <Icon name="clock" class="w-6 h-6 text-primary" />
              </div>
              <div>
                <h3 class="font-semibold text-lg">Disponibilité</h3>
                <p class="text-gray-600 mt-1">
                  Lundi – Vendredi : 9h00 – 18h00<br />
                  Réponse email sous 48h
                </p>
              </div>
            </div>
          </div>

          <div class="mt-12 text-center">
            <h3 class="font-semibold text-lg mb-4">Suivez-nous</h3>
            <div class="flex justify-center space-x-4">
              <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="bg-gray-100 hover:bg-primary hover:text-white p-3 rounded-full transition-colors">
                <Icon name="linkedin" class="w-5 h-5" />
              </a>
            </div>
          </div>
        </div>

        <div class="text-center mb-12">
          <p class="text-lg text-gray-700 mb-6">La façon la plus rapide d'avancer : remplir le formulaire d'audit gratuit. On revient vers vous avec une analyse personnalisée sous 48h.</p>
          <button
            type="button"
            onclick="openModal()"
            class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold py-4 px-10 rounded-xl transition-colors text-lg"
          >
            Démarrer mon audit gratuit
          </button>
          <p class="text-sm text-gray-400 mt-3">Sans engagement • Réponse sous 48h</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="bg-gray-50 py-20">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold mb-8 text-center">Nous trouver</h2>
      <div class="max-w-6xl mx-auto rounded-2xl overflow-hidden shadow-lg h-96">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2624.2214295218523!2d2.3454683!3d48.8731857!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47e66e1bdff9a6a7%3A0x36ffd52f692c674!2s35%20Rue%20du%20Faubourg%20Poissonnière%2C%2075009%20Paris!5e0!3m2!1sfr!2sfr!4v1651234567890!5m2!1sfr!2sfr"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- FAQ Section avec JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  })} />

  <section class="py-20">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-12 text-center">Questions fréquentes</h2>

      <div class="max-w-4xl mx-auto space-y-6">
        {faqs.map(faq => (
          <div class="bg-white rounded-xl shadow-md overflow-hidden">
            <button class="w-full px-6 py-4 text-left font-semibold flex justify-between items-center focus:outline-none">
              <span>{faq.question}</span>
              <Icon name="chevron-down" class="w-5 h-5 text-gray-500 flex-shrink-0 ml-4" />
            </button>
            <div class="px-6 pb-4">
              <p class="text-gray-600">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="bg-primary text-white py-20">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-6">Prêt à gagner du temps avec l'IA ?</h2>
      <p class="text-xl mb-8 text-gray-200">Obtenez votre audit gratuit et découvrez quelles tâches automatiser en priorité.</p>
      <button
        type="button"
        onclick="openModal()"
        class="bg-secondary hover:bg-secondary-light text-primary font-semibold px-8 py-4 rounded-lg transition-colors text-lg"
      >
        Démarrer mon audit gratuit
      </button>
      <p class="text-sm mt-4 text-gray-300">Réponse sous 48h • Sans engagement</p>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('.bg-white.rounded-xl.shadow-md');

    faqItems.forEach(item => {
      const content = item.querySelector('button + div') as HTMLElement;
      if (content) {
        content.style.height = '0';
        content.style.opacity = '0';
        content.style.visibility = 'hidden';
      }
    });

    const faqButtons = document.querySelectorAll('.bg-white.rounded-xl.shadow-md button');
    faqButtons.forEach(button => {
      button.addEventListener('click', () => {
        const content = button.nextElementSibling as HTMLElement;
        const icon = button.querySelector('svg') as HTMLElement;
        const isOpen = content?.style.visibility === 'visible';

        faqItems.forEach(otherItem => {
          const otherContent = otherItem.querySelector('button + div') as HTMLElement;
          const otherIcon = otherItem.querySelector('svg') as HTMLElement;
          if (otherContent) { otherContent.style.height = '0'; otherContent.style.opacity = '0'; otherContent.style.visibility = 'hidden'; }
          if (otherIcon) otherIcon.style.transform = 'rotate(0deg)';
        });

        if (!isOpen && content) {
          content.style.visibility = 'visible';
          content.style.height = content.scrollHeight + 'px';
          content.style.opacity = '1';
          if (icon) icon.style.transform = 'rotate(180deg)';
        }
      });
    });
  });
</script>

<style>
  .bg-white.rounded-xl button svg { transition: transform 0.3s ease; }
  .bg-white.rounded-xl button + div { transition: all 0.3s ease-in-out; overflow: hidden; }
</style>
