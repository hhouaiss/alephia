---
import Layout from '../layouts/Layout.astro';
import AuditModal from '../components/shared/AuditModal.astro';
import Icon from '../components/shared/Icon.astro';
import ValuesSection from '../components/sections/ValuesSection.astro';

const seoTitle = "À propos d'Alefia — Agence IA & Automatisation à Paris";
const seoDescription = "Alefia est une agence spécialisée en automatisation IA et agents IA pour PME, TPE et indépendants. +8 ans d'expérience. Clients : BNP Paribas, Wonderbox, Crédit Mutuel.";
---

<Layout title={seoTitle} description={seoDescription}>
  <AuditModal />

  <!-- Page Header -->
  <div class="bg-primary text-white pt-40 pb-20">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">À propos d'Alefia</h1>
      <p class="text-xl max-w-3xl text-gray-200">
        Nous aidons les PME, TPE et indépendants à automatiser leurs processus métier avec l'IA — pour gagner du temps, réduire les coûts et se concentrer sur ce qui compte vraiment.
      </p>
    </div>
  </div>

  <!-- Main Content -->
  <div class="py-16">
    <div class="container mx-auto px-4">
      <div class="prose prose-lg max-w-4xl mx-auto">

        <h2>Notre mission</h2>
        <p>
          Chez Alefia, notre mission est claire : <strong>rendre l'automatisation IA accessible à toutes les entreprises</strong>, quelle que soit leur taille. Nous transformons les processus manuels et répétitifs en workflows intelligents qui travaillent pour vous — en permanence.
        </p>
        <p>
          Fondée par un expert avec plus de 8 ans d'expérience en développement web et intégration IA, Alefia est née d'un constat simple : la plupart des PME et TPE perdent des dizaines d'heures par semaine sur des tâches que l'IA peut automatiser en quelques jours.
        </p>

        <h2>Notre approche</h2>
        <p>
          Nous ne vendons pas de la technologie pour la technologie. Nous vendons du <strong>temps retrouvé</strong> et des <strong>coûts réduits</strong>.
        </p>
        <p>
          Chaque projet commence par un audit gratuit de vos processus. On identifie ensemble les tâches à automatiser en priorité, on déploie les premiers agents IA sous 48h, et on vous accompagne jusqu'à l'adoption complète par vos équipes.
        </p>

        <h2>Nos domaines d'expertise</h2>

        <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-6 my-8">
          {[
            { icon: 'settings', title: 'Agents IA sur mesure', desc: 'Claude Agents, assistants métier, chatbots intelligents adaptés à votre secteur.' },
            { icon: 'chart', title: 'Automatisation de workflows', desc: 'n8n, Make, Zapier — vos outils connectés, vos processus automatisés.' },
            { icon: 'tools', title: 'Intégration IA dans vos outils', desc: 'CRM, ERP, outils métier — l\'IA s\'intègre sans tout réinventer.' },
            { icon: 'trending-up', title: 'Analyse de données IA', desc: 'Dashboards automatiques, reporting IA, insights actionnables.' },
            { icon: 'heart', title: 'Formation & conseil IA', desc: 'Stratégie IA, formation de vos équipes, accompagnement sur la durée.' }
          ].map(item => (
            <div class="flex items-start gap-4 bg-gray-50 p-5 rounded-xl">
              <div class="bg-primary/10 p-2 rounded-lg flex-shrink-0">
                <Icon name={item.icon} class="w-6 h-6 text-primary" />
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">{item.title}</h3>
                <p class="text-gray-600 text-sm mt-1">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <h2>Références clients</h2>
        <p>
          Nos interventions couvrent des secteurs variés, de la grande banque à l'e-commerce en passant par les services :
        </p>

        <div class="not-prose flex flex-wrap gap-3 my-6">
          {['BNP Paribas', 'Hello bank!', 'Crédit Mutuel', 'CIC', 'Société Générale', 'Wonderbox'].map(client => (
            <span class="bg-white border border-gray-200 rounded-lg px-5 py-2 font-semibold text-gray-700 shadow-sm">
              {client}
            </span>
          ))}
        </div>

        <h2>Notre engagement</h2>
        <p>Avec Alefia, vous bénéficiez :</p>
        <ul>
          <li><strong>D'un déploiement rapide</strong> — premier résultat sous 48h, pas 6 mois</li>
          <li><strong>D'une approche sans jargon</strong> — on traduit la technologie en bénéfices métier concrets</li>
          <li><strong>D'un accompagnement humain</strong> — un expert dédié, pas un support anonyme</li>
          <li><strong>De solutions pérennes</strong> — vos automatisations évoluent avec votre activité</li>
        </ul>

      </div>
    </div>
  </div>

  <ValuesSection />

  <!-- CTA Final -->
  <section class="bg-primary text-white py-20">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-6">Discutons de votre projet IA</h2>
      <p class="text-xl mb-8 text-gray-200">Obtenez votre audit gratuit et découvrez vos opportunités d'automatisation.</p>
      <button
        type="button"
        onclick="openModal()"
        class="bg-secondary hover:bg-secondary-light text-primary font-semibold px-8 py-4 rounded-lg transition-colors text-lg"
      >
        Démarrer mon audit gratuit
      </button>
      <p class="text-sm mt-4 text-gray-300">Réponse personnalisée sous 48h • Sans engagement</p>
    </div>
  </section>
</Layout>
