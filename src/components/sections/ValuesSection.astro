---
import Icon from '../shared/Icon.astro';
import type { IconName } from '../../utils/icons';

type ColorKey = 'blue' | 'red' | 'green' | 'purple';

const values: { icon: IconName; title: string; description: string; color: ColorKey }[] = [
  {
    icon: 'trending-up',
    title: 'Résultats rapides',
    description: 'Premier agent IA déployé en 48h. Vous voyez les gains dès la première semaine.',
    color: 'green'
  },
  {
    icon: 'settings',
    title: 'Sur mesure, pas générique',
    description: 'Chaque automatisation est conçue pour vos processus spécifiques, pas pour une cible abstraite.',
    color: 'purple'
  },
  {
    icon: 'shield',
    title: 'Simple à utiliser',
    description: 'Vos équipes n\'ont pas besoin de compétences techniques. On s\'occupe de tout, de A à Z.',
    color: 'blue'
  },
  {
    icon: 'heart',
    title: 'Accompagnement humain',
    description: 'Un expert dédié vous suit à chaque étape — de l\'audit jusqu\'à l\'adoption par vos équipes.',
    color: 'red'
  }
];

const colorVariants: Record<ColorKey, string> = {
  blue: 'bg-blue-50 text-blue-600',
  red: 'bg-red-50 text-red-600',
  green: 'bg-green-50 text-green-600',
  purple: 'bg-purple-50 text-purple-600'
};
---

<section class="py-24 bg-gradient-to-b from-white to-neutral-50">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold mb-6">
        Pourquoi choisir Alefia ?
      </h2>
      <p class="text-xl text-gray-600">
        Une approche pragmatique de l'IA : des résultats concrets, pas des promesses.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {values.map(value => (
        <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 group">
          <div class={`w-16 h-16 rounded-xl flex items-center justify-center mb-6 transition-transform group-hover:scale-110 ${colorVariants[value.color]}`}>
            <Icon name={value.icon} />
          </div>
          <div class="space-y-4">
            <h3 class="text-xl font-semibold">{value.title}</h3>
            <p class="text-gray-600 leading-relaxed">{value.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
