---
import Icon from '../shared/Icon.astro';

const useCases = [
  {
    icon: 'mail',
    title: 'Gestion des emails et relances clients',
    description: 'Un agent IA trie, répond et relance automatiquement vos clients. Zéro email oublié, zéro heure perdue.'
  },
  {
    icon: 'chart',
    title: 'Devis et documents automatisés',
    description: 'Générez vos devis, factures et rapports en quelques secondes à partir de vos données existantes.'
  },
  {
    icon: 'settings',
    title: 'Automatisation de vos processus internes',
    description: 'Connectez vos outils (CRM, ERP, tableurs) et éliminez les saisies manuelles répétitives une bonne fois pour toutes.'
  },
  {
    icon: 'message',
    title: 'Assistant métier disponible 24h/24',
    description: 'Un agent IA formé sur vos données répond à vos clients, collaborateurs ou prospects à toute heure.'
  }
];
---

<section id="use-cases" class="py-24 bg-gradient-to-b from-primary-dark/5 to-transparent">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <h2 class="text-4xl font-bold mb-6">
        Concrets, rapides, mesurables
      </h2>
      <p class="text-xl text-gray-600">
        Voici comment nos agents IA et nos automatisations transforment le quotidien de nos clients.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
      {useCases.map(useCase => (
        <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 group">
          <div class="bg-primary/10 w-16 h-16 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <Icon name={useCase.icon as "chart" | "settings" | "arrow-right" | "trending-up" | "clock" | "shield" | "tools" | "mail" | "heart" | "download" | "rocket" | "message"} class="text-primary" />
          </div>
          <h3 class="text-xl font-semibold mb-4">{useCase.title}</h3>
          <p class="text-gray-600 leading-relaxed">{useCase.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center">
      <button
        type="button"
        onclick="openModal()"
        class="bg-primary text-white px-8 py-4 rounded-xl hover:bg-primary-dark transition-all duration-300 inline-flex items-center gap-2 group"
      >
        Obtenir mon audit gratuit
        <Icon name="arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
      </button>
    </div>
  </div>
</section>
