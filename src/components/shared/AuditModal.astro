---
import Icon from './Icon.astro';
import StepIndicator from './form/StepIndicator.astro';
import Step1Form from './form/Step1Form.astro';
import Step2Form from './form/Step2Form.astro';
import Step3Confirmation from './form/Step3Confirmation.astro';
---

<div
  id="audit-modal"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
>
  <div class="fixed inset-0 bg-black/50 backdrop-blur-sm" id="modal-backdrop"></div>

  <div class="fixed inset-0 overflow-y-auto">
    <div class="flex min-h-full items-center justify-center p-4">
      <div class="relative w-full max-w-lg bg-white rounded-2xl shadow-xl">
        <!-- Close button -->
        <button
          type="button"
          id="modal-close-button"
          class="absolute right-4 top-4 z-10 p-2 text-gray-400 hover:text-gray-600 rounded-full hover:bg-gray-100 transition-colors"
          aria-label="Fermer"
        >
          <Icon name="x" class="w-6 h-6" />
        </button>

        <div class="p-6 sm:p-8">
          <!-- Header -->
          <div class="text-center mb-6" id="modal-header">
            <h2 class="text-2xl font-bold text-gray-900 mb-1">Audit IA gratuit</h2>
            <p class="text-gray-500 text-sm">Analyse personnalisée de vos opportunités d'automatisation</p>
          </div>

          <!-- Step indicator -->
          <div id="step-indicator-wrapper" class="mb-8">
            <StepIndicator />
          </div>

          <!-- Steps -->
          <div id="step-1">
            <Step1Form />
          </div>

          <div id="step-2" class="hidden">
            <Step2Form />
          </div>

          <div id="step-3" class="hidden">
            <Step3Confirmation />
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.formData = window.formData || {};

  // Show/hide steps
  window.showStep = (step: number) => {
    [1, 2, 3].forEach(n => {
      const el = document.getElementById(`step-${n}`);
      if (el) el.classList.toggle('hidden', n !== step);
    });

    const header = document.getElementById('modal-header');
    const indicator = document.getElementById('step-indicator-wrapper');

    if (step === 3) {
      if (header) header.classList.add('hidden');
      if (indicator) indicator.classList.add('hidden');
    } else {
      if (header) header.classList.remove('hidden');
      if (indicator) indicator.classList.remove('hidden');
    }

    if (typeof window.updateStepIndicators === 'function') {
      window.updateStepIndicators(step);
    }
  };

  // Submit full form
  window.submitForm = async () => {
    try {
      await fetch('/api/audit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(window.formData)
      });

      if (window.formData.email) {
        localStorage.setItem('userEmail', window.formData.email);
      }

      if (typeof window.gtag === 'function') {
        window.gtag('event', 'audit_form_submit', {
          event_category: 'conversion',
          event_label: 'audit_gratuit'
        });
      }
    } catch (err) {
      console.error('Submission error:', err);
    } finally {
      window.showStep(3);
    }
  };

  const resetModal = () => {
    window.formData = {};
    window.showStep(1);
    document.getElementById('step1-form')?.reset();
    document.getElementById('step2-form')?.reset();
  };

  // Open/close
  window.openModal = () => {
    const modal = document.getElementById('audit-modal');
    modal?.classList.remove('hidden');
    resetModal();

    const savedEmail = localStorage.getItem('userEmail');
    if (savedEmail) {
      const emailInput = document.getElementById('email') as HTMLInputElement;
      if (emailInput) emailInput.value = savedEmail;
    }
  };

  window.closeModal = () => {
    document.getElementById('audit-modal')?.classList.add('hidden');
  };

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('modal-close-button')?.addEventListener('click', () => window.closeModal());
    document.getElementById('modal-backdrop')?.addEventListener('click', () => window.closeModal());
  });
</script>
