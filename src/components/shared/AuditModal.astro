---
import Icon from './Icon.astro';
import Step1Form from './form/Step1Form.astro';
import Step3Confirmation from './form/Step3Confirmation.astro';
---

<div
  id="audit-modal"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
>
  <div class="fixed inset-0 bg-black/50 backdrop-blur-sm" id="modal-backdrop"></div>

  <div class="fixed inset-0 overflow-y-auto">
    <div class="flex min-h-full items-center justify-center p-4">
      <div class="relative w-full max-w-lg bg-white rounded-2xl shadow-xl">
        <!-- Close button -->
        <button
          type="button"
          id="modal-close-button"
          class="absolute right-4 top-4 z-10 p-2 text-gray-400 hover:text-gray-600 rounded-full hover:bg-gray-100 transition-colors"
          aria-label="Fermer"
        >
          <Icon name="x" class="w-6 h-6" />
        </button>

        <div class="p-6 sm:p-8">
          <!-- Header -->
          <div class="text-center mb-6" id="modal-header">
            <h2 class="text-2xl font-bold text-gray-900 mb-1">Audit IA gratuit</h2>
            <p class="text-gray-500 text-sm">Analyse personnalisée de vos opportunités d'automatisation</p>
          </div>

          <!-- Form -->
          <div id="step-1">
            <Step1Form />
          </div>

          <!-- Confirmation -->
          <div id="step-3" class="hidden">
            <Step3Confirmation />
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.formData = window.formData || {};

  window.showStep = (step: number) => {
    const step1 = document.getElementById('step-1');
    const step3 = document.getElementById('step-3');
    const header = document.getElementById('modal-header');

    if (step === 1) {
      step1?.classList.remove('hidden');
      step3?.classList.add('hidden');
      header?.classList.remove('hidden');
    } else if (step === 3) {
      step1?.classList.add('hidden');
      step3?.classList.remove('hidden');
      header?.classList.add('hidden');
    }
  };

  window.submitForm = async () => {
    try {
      await fetch('/api/audit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(window.formData)
      });

      if (typeof window.gtag === 'function') {
        window.gtag('event', 'audit_form_submitted', {
          event_category: 'lead',
          event_label: 'audit_gratuit',
          value: 150,
          currency: 'EUR'
        });
      }

      // dataLayer push for GTM / Google Ads conversion
      if (typeof window.dataLayer !== 'undefined') {
        window.dataLayer.push({
          event: 'audit_form_submitted',
          event_category: 'lead',
          event_label: 'audit_gratuit',
          value: 150,
          currency: 'EUR'
        });
      }
    } catch (err) {
      console.error('Submission error:', err);
    } finally {
      window.showStep(3);
    }
  };

  const resetModal = () => {
    window.formData = {};
    window.showStep(1);
    const form = document.getElementById('step1-form') as HTMLFormElement;
    form?.reset();
  };

  window.openModal = () => {
    const modal = document.getElementById('audit-modal');
    modal?.classList.remove('hidden');
    resetModal();

    // Pre-fill email from localStorage
    const savedEmail = localStorage.getItem('userEmail');
    if (savedEmail) {
      const emailInput = document.getElementById('email') as HTMLInputElement;
      if (emailInput) emailInput.value = savedEmail;
    }
  };

  window.closeModal = () => {
    document.getElementById('audit-modal')?.classList.add('hidden');
  };

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('modal-close-button')?.addEventListener('click', () => window.closeModal());
    document.getElementById('modal-backdrop')?.addEventListener('click', () => window.closeModal());
  });
</script>
