---
import Icon from '../Icon.astro';
---

<div class="text-center space-y-8 py-4">
  <!-- Header -->
  <div class="mb-2">
    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <Icon name="check" class="w-8 h-8 text-green-600" />
    </div>
    <h3 class="text-2xl md:text-3xl font-bold text-gray-900 max-w-md mx-auto leading-tight">
      Merci <span id="user-first-name" class="text-primary"></span> !
    </h3>
    <p class="text-gray-600 mt-2">Votre audit IA est en préparation.</p>
    <p class="text-gray-500 text-sm mt-1">Vous recevrez une réponse personnalisée sous 48h.</p>
  </div>

  <!-- What's next -->
  <div class="bg-gray-50 rounded-xl p-6 max-w-md mx-auto border border-gray-100 text-left">
    <p class="font-semibold mb-4 text-gray-800">Ce que contiendra votre audit :</p>
    <ul class="space-y-3 text-gray-700">
      <li class="flex items-start">
        <div class="bg-primary/10 rounded-full p-1 mr-3 mt-0.5 flex-shrink-0">
          <Icon name="check" class="w-4 h-4 text-primary" />
        </div>
        <span>Les 3 tâches de votre business à automatiser en priorité</span>
      </li>
      <li class="flex items-start">
        <div class="bg-primary/10 rounded-full p-1 mr-3 mt-0.5 flex-shrink-0">
          <Icon name="check" class="w-4 h-4 text-primary" />
        </div>
        <span>Les outils recommandés (agents IA, n8n, Make, Zapier...)</span>
      </li>
      <li class="flex items-start">
        <div class="bg-primary/10 rounded-full p-1 mr-3 mt-0.5 flex-shrink-0">
          <Icon name="check" class="w-4 h-4 text-primary" />
        </div>
        <span>Une estimation du temps gagné par semaine</span>
      </li>
      <li class="flex items-start">
        <div class="bg-primary/10 rounded-full p-1 mr-3 mt-0.5 flex-shrink-0">
          <Icon name="check" class="w-4 h-4 text-primary" />
        </div>
        <span>Un plan d'action concret pour démarrer rapidement</span>
      </li>
    </ul>
  </div>

  <!-- CTA -->
  <div class="max-w-md mx-auto">
    <a
      href="https://calendly.com/meet-alefia/30min"
      target="_blank"
      rel="noopener noreferrer"
      class="w-full bg-primary text-white px-8 py-4 rounded-xl hover:bg-primary-dark transition-all duration-300 shadow-md hover:shadow-lg flex items-center justify-center gap-2 hover:scale-[1.02] font-medium cursor-pointer"
    >
      <span>Réserver un créneau de 15 min avec Hassan</span>
    </a>
    <p class="text-gray-500 text-sm mt-3">
      Sans engagement • Vous recevrez votre audit par email sous 48h
    </p>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const step3 = document.getElementById('step-3');

    const observer = new MutationObserver(() => {
      if (step3 && !step3.classList.contains('hidden')) {
        const firstNameEl = document.getElementById('user-first-name');
        if (firstNameEl && window.formData?.firstName) {
          firstNameEl.textContent = window.formData.firstName;
        }
      }
    });

    if (step3) {
      observer.observe(step3, { attributes: true, attributeFilter: ['class'] });
    }
  });
</script>
