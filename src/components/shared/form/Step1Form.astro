---
---

<form id="step1-form" class="space-y-5">
  <div>
    <label for="firstName" class="block text-sm font-medium text-gray-700 mb-1">
      Prénom <span class="text-red-500">*</span>
    </label>
    <input
      type="text"
      id="firstName"
      name="firstName"
      required
      placeholder="Votre prénom"
      class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-colors"
    />
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
      Email professionnel <span class="text-red-500">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      placeholder="vous@entreprise.com"
      class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-colors"
    />
  </div>

  <div>
    <label for="besoin" class="block text-sm font-medium text-gray-700 mb-1">
      Votre besoin principal <span class="text-gray-400 font-normal">(optionnel)</span>
    </label>
    <textarea
      id="besoin"
      name="besoin"
      rows="3"
      placeholder="Ex : automatiser mes devis, gérer mes emails clients, analyser mes données..."
      class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-colors resize-none"
    ></textarea>
  </div>

  <button
    type="submit"
    class="w-full bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-4 rounded-xl transition-all duration-200 hover:shadow-lg hover:scale-[1.01] text-base"
  >
    Recevoir mon audit gratuit
  </button>

  <p class="text-center text-sm text-gray-500">
    Réponse personnalisée sous 48h • Sans engagement • 100% gratuit
  </p>
</form>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Pre-fill email from localStorage or URL param
    const savedEmail = localStorage.getItem('userEmail');
    const emailInput = document.getElementById('email') as HTMLInputElement;
    if (emailInput && savedEmail) {
      emailInput.value = savedEmail;
    }

    const form = document.getElementById('step1-form');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const formData = new FormData(e.target as HTMLFormElement);
      Object.assign(window.formData, Object.fromEntries(formData));

      if (window.formData.email) {
        localStorage.setItem('userEmail', window.formData.email as string);
      }

      // Ajouter les UTMs depuis sessionStorage (Google Ads tracking)
      ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'].forEach(key => {
        const val = sessionStorage.getItem(key);
        if (val) window.formData[key] = val;
      });

      if (typeof window.submitForm === 'function') {
        window.submitForm();
      }
    });
  });
</script>
